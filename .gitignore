node_modules/

# -------------------------------------------------------------------------
# Rust Build Artifacts
# -------------------------------------------------------------------------
# The target directory contains all compiled binaries, object files, 
# and build scripts generated by Cargo.
/target/

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Backup files generated by the rustfmt tool
**/*.rs.bk

# -------------------------------------------------------------------------
# Executables and Binaries (Recursive)
# -------------------------------------------------------------------------
# Ignores executables anywhere in the project, not just in the target folder.
**/*.exe
**/*.bin
**/*.out
**/*.dll
**/*.so
**/*.dylib

# -------------------------------------------------------------------------
# Log Files (Recursive)
# -------------------------------------------------------------------------
# Ignores any log files generated by your application or debugging tools
**/*.log
**/logs/
**/target/

# Optional: Ignore crash dumps or panic logs
**/*.dmp
**/*.crash

# -------------------------------------------------------------------------
# Environment and OS Files
# -------------------------------------------------------------------------
.env
.DS_Store
Thumbs.db

# -------------------------------------------------------------------------
# Cargo.lock (Read the note below before using!)
# -------------------------------------------------------------------------
# Cargo.lock